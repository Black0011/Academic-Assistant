# =========================================================================
# Academic Agent Framework — OFFLINE / fully-local profile
#
# Goal: zero outbound API calls. Chat goes through Ollama (local llama
# server), embeddings come from a local sentence-transformers model.
# Same SQLite + in-memory queue layout as `.env.laptop.example` so the
# resource budget stays laptop-friendly.
#
# Prereqs:
#   1. Install Ollama (https://ollama.com), then `ollama pull llama3.1:8b`
#      (or any model you prefer; just match OLLAMA_DEFAULT_MODEL below).
#   2. Install the sentence-transformers extra:
#        uv sync --extra offline
#      The first vector-store query downloads the embedding model
#      (default: BAAI/bge-small-en-v1.5, ~133 MB) into HuggingFace's
#      cache; subsequent boots are instant.
#
# Usage:
#   cp .env.offline.example .env.laptop          # reuse the dev-laptop pipe
#   make dev-laptop                              # boot
#   # or, fully containerised:
#   docker compose -f docker-compose.lite.yml --env-file .env.laptop up -d
# =========================================================================

# ---- Inherit the laptop preset's zero-ops storage ------------------------
AAF_ENV=development
AAF_WORKDIR=./data
AAF_LOG_LEVEL=INFO
AAF_SECRET_KEY=local-dev-only-change-if-you-care

AUTH_DISABLED=true
USERS_DIR=./data/users

DATABASE_URL=sqlite+aiosqlite:///./data/aaf.db
REDIS_URL=
AAF_TASK_QUEUE_BACKEND=inmemory
AAF_TASK_STORE_BACKEND=sql
MEMORY_VECTOR_BACKEND=memory
MEMORY_SESSION_BACKEND=memory

# ---- Chat: Ollama (no API key required) ---------------------------------
DEFAULT_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# Whatever you `ollama pull`-ed.
OLLAMA_DEFAULT_MODEL=llama3.1:8b

# ---- Embeddings: local sentence-transformers ----------------------------
# Switch the embedder slot from "reuse chat LLM" to "local model".
AAF_EMBEDDING_BACKEND=local
# Default is BAAI/bge-small-en-v1.5 (133 MB, 384-dim, English).
# Other good picks:
#   AAF_LOCAL_EMBEDDING_MODEL=BAAI/bge-m3                    # multilingual, 568 MB
#   AAF_LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2  # tiny, 90 MB
AAF_LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Auto-detect (cuda > mps > cpu). Force with "cpu" / "cuda" / "mps" if needed.
# AAF_LOCAL_EMBEDDING_DEVICE=cpu
# Override HuggingFace cache location (defaults to ~/.cache/huggingface).
# AAF_LOCAL_EMBEDDING_CACHE_FOLDER=./data/hf_cache

# ---- Per-task model routing ---------------------------------------------
# With Ollama as the only chat provider, you can still route between
# different local models via config/model_routing.yaml (e.g. fast=
# llama3.1:8b, reasoning=deepseek-r1:14b once pulled).
AAF_MODEL_ROUTING_CONFIG=./config/model_routing.yaml

# ---- Auto-compaction (recommended for small local models) ---------------
# Smaller local models have tighter context windows than hosted ones;
# auto-compaction earns its keep faster here.
AAF_AUTOCOMPACT_ENABLED=true
AAF_AUTOCOMPACT_THRESHOLD=0.6
AAF_AUTOCOMPACT_KEEP_RECENT_N=4
AAF_AUTOCOMPACT_SUMMARISER_ROUTE=fast

# ---- MCP / Evolver (off by default, opt in once trusted) ----------------
AAF_MCP_ENABLED=false
AAF_MCP_CONFIG=./config/mcp_servers.yaml
AAF_EVOLVER_ENABLED=false

# ---- Limits / Budgets (laptop) ------------------------------------------
AAF_MAX_PARALLEL_TASKS=2
# Local models cost nothing to run; this is just a circuit breaker for
# runaway loops measured in (synthesised) token cost.
AAF_DEFAULT_BUDGET_USD=0.5
AAF_SKILL_EXEC_TIMEOUT_S=120
AAF_CHECKPOINT_ENABLED=false
AAF_ALLOW_NETWORK=true
AAF_ALLOW_PAID_APIS=false

AAF_PROPOSALS_BACKEND=yaml
AAF_PROPOSALS_DIR=./data/proposals
AAF_PLANNER_DEFAULT_MAX_NODES=20
AAF_PLANNER_DEFAULT_RETRY=1
AAF_PLANNER_MAX_PARALLEL=2
