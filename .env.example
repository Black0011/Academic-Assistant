# =========================================================================
# Academic Agent Framework — configuration
# =========================================================================
# Copy this file to .env and fill in your values:
#     cp .env.example .env
# =========================================================================

# ---- LLM Provider (required) --------------------------------------------
# Supported: openai, deepseek, ollama
DEFAULT_LLM_PROVIDER=openai

# OpenAI-compatible endpoint (DeepSeek recommended for Chinese users)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_DEFAULT_MODEL=deepseek-v4-flash
# DeepSeek may need this on Windows: OPENAI_VERIFY_SSL=false

# ---- Anthropic (alternative) --------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# ---- Ollama (local, no key needed) --------------------------------------
# DEFAULT_LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_DEFAULT_MODEL=llama3.1:8b

# ---- Data storage -------------------------------------------------------
AAF_DATABASE_URL=sqlite:///data/aaf.db
AAF_KNOWLEDGE_PATH=./data/knowledge
AAF_MANUSCRIPTS_PATH=./data/manuscripts

# ---- MCP Servers (Google Scholar) ---------------------------------------
AAF_MCP_ENABLED=true
AAF_MCP_CONFIG=./config/mcp_servers.yaml

# ---- Proxy / VPN (for Chinese users to access arxiv/Google Scholar) -----
# If you have Clash/V2Ray, set this to your proxy port:
# AAF_HTTPS_PROXY=http://127.0.0.1:7890

# ---- Task execution -----------------------------------------------------
AAF_MAX_PARALLEL_TASKS=2
AAF_DEFAULT_BUDGET_USD=0.5
AAF_TASK_QUEUE_BACKEND=inmemory

# ---- Auto-compaction (disable for research agent) -----------------------
AAF_AUTOCOMPACT_ENABLED=false

# ---- Embedding (optional) -----------------------------------------------
# AAF_EMBEDDING_BACKEND=local
# AAF_LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
