# =========================================================================
# Academic Agent Framework — Environment Template
#
# Copy this file to `.env` and edit as needed:
#     cp .env.example .env
#
# Every key listed here corresponds to a field on `backend/settings.py`
# (BaseSettings is case-insensitive, so e.g. JWT_EXPIRE_SECONDS maps to
# `Settings.jwt_expire_seconds`). Keys not present in Settings are silently
# ignored — except where docker-compose reads them itself (POSTGRES_PASSWORD,
# AAF_HTTP_PORT, MINIO_*).
#
# *Never* commit your filled-in `.env` to git.
# =========================================================================

# ---- Core ----------------------------------------------------------------
AAF_ENV=production                          # development | production | test
AAF_WORKDIR=/data                           # data root inside containers (./data on host)
AAF_LOG_LEVEL=INFO
AAF_SECRET_KEY=change-me-to-a-long-random-string

# ---- Auth ----------------------------------------------------------------
# Set to false in production. The first user to register becomes admin.
AUTH_DISABLED=false
AUTH_ALLOW_SIGNUP=true                      # disable after onboarding
JWT_EXPIRE_SECONDS=86400
USERS_DIR=/data/users                       # YAML user store on disk

# ---- Datastores ----------------------------------------------------------
# DATABASE_URL is overridden in docker-compose to point at the postgres service.
# For host-side development (make dev) the SQLite default below works.
DATABASE_URL=sqlite+aiosqlite:///./data/aaf.db
REDIS_URL=redis://localhost:6379/0
CHROMA_PERSIST_DIR=/data/chroma

# ---- Long-running tasks --------------------------------------------------
# Both default to "auto": API picks `arq` only when env=production AND redis
# is reachable AND the arq lib is importable. Pin explicitly for clarity.
AAF_TASK_QUEUE_BACKEND=arq                  # auto | inmemory | arq
AAF_TASK_STORE_BACKEND=sql                  # auto | inmemory | sql

# ---- LLM Providers -------------------------------------------------------
# AAF falls back to a deterministic mock provider if no credentials are set,
# so the stack still boots in zero-config demos. Wire at least one provider
# here for real work.
DEFAULT_LLM_PROVIDER=openai

# OpenAI (or any OpenAI-compatible endpoint: DeepSeek, Moonshot, vLLM …)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-latest

# Local models via Ollama (OpenAI-compatible)
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# ---- Per-task model routing (optional) ----------------------------------
# Drop a YAML at this path (template at config/model_routing.example.yaml)
# to enable RoutingLLMProvider — workflows then call
# `ctx.llm.for_route("reasoning")` / `"fast"` / etc. for per-task model
# selection. Absent file = single-provider mode (default DEFAULT_LLM_PROVIDER
# everywhere, fully backward-compatible).
AAF_MODEL_ROUTING_CONFIG=./config/model_routing.yaml

# ---- Context auto-compaction (optional) ---------------------------------
# When enabled, AAF wraps the LLM provider in CompactingLLMProvider: any
# complete() call whose input would exceed `threshold * context_window`
# triggers a one-shot summariser pass (via `summariser_route` if routing
# is wired) that collapses the middle of the conversation into a single
# system message while preserving system + the last `keep_recent_n`
# non-system turns. Off by default — it costs an extra LLM call per
# fire, only worth it for long-running workflows.
AAF_AUTOCOMPACT_ENABLED=false
AAF_AUTOCOMPACT_THRESHOLD=0.7
AAF_AUTOCOMPACT_KEEP_RECENT_N=6
AAF_AUTOCOMPACT_SUMMARISER_ROUTE=fast

# ---- Embedding -----------------------------------------------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Embedding backend selection. ``provider`` (default) reuses the chat
# LLM's embed() implementation. Switch to ``local`` to run a
# sentence-transformers model in-process — no API calls — useful for
# fully-offline boot. Requires `uv sync --extra offline` (pulls torch).
AAF_EMBEDDING_BACKEND=provider              # provider | local
AAF_LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Force device explicitly when auto-detection picks the wrong one.
# AAF_LOCAL_EMBEDDING_DEVICE=cpu            # cpu | cuda | mps | ...
# Override HuggingFace cache location (default: ~/.cache/huggingface).
# AAF_LOCAL_EMBEDDING_CACHE_FOLDER=./data/hf_cache

# ---- External Tools (optional) ------------------------------------------
SEMANTIC_SCHOLAR_API_KEY=
TAVILY_API_KEY=
TECTONIC_PATH=/usr/local/bin/tectonic

# ---- Limits / Budgets ----------------------------------------------------
AAF_MAX_PARALLEL_TASKS=4
AAF_DEFAULT_BUDGET_USD=2.0
AAF_SKILL_EXEC_TIMEOUT_S=120
AAF_CHECKPOINT_ENABLED=false
AAF_ALLOW_NETWORK=true
AAF_ALLOW_PAID_APIS=true

# ---- M8.1 · Gated proposals ---------------------------------------------
# `apply` only stamps status — it never modifies files. The diff field is the
# input for humans / CI to consume.
AAF_PROPOSALS_BACKEND=auto                  # auto | memory | yaml
AAF_PROPOSALS_DIR=./data/proposals

# ---- MCP servers (optional) ---------------------------------------------
# AAF can consume any Model-Context-Protocol server (stdio or SSE) and
# expose its tools through the same ToolRegistry workflows already use.
# The discovered tools are namespaced as `mcp__<server>__<tool>`. Off by
# default; flip ENABLED=true *and* point CONFIG at a YAML to activate.
# Template at config/mcp_servers.example.yaml.
AAF_MCP_ENABLED=false
AAF_MCP_CONFIG=./config/mcp_servers.yaml

# ---- Self-evolution (optional) ------------------------------------------
# When enabled, EvolverAgent inspects every successful workflow run and
# drafts a heuristic Proposal (status=draft) into the gated proposal
# store. Human review through `/api/v1/proposals` is required before
# the heuristic takes effect — the agent NEVER writes to HeuristicStore
# directly. Off by default to keep the proposal queue tidy.
AAF_EVOLVER_ENABLED=false

# ---- M8.2 · Planner DAG -------------------------------------------------
# Optional planner agent: compile a NL goal into a PlanDAG, then execute it
# through the standard Task system (workflow="dag").
AAF_PLANNER_DEFAULT_MAX_NODES=30
AAF_PLANNER_DEFAULT_RETRY=1
AAF_PLANNER_MAX_PARALLEL=4

# ---- P7 · Manuscript bundles --------------------------------------------
# Project-shaped manuscripts (overleaf/, plan/, experiments/, …) live as
# real directory trees. Two physical placements:
#   * "copy"  — AAF owns ./data/manuscripts/<id>/work (default for new bundles)
#   * "link"  — bundle_link_path on the manuscript points at a directory you
#               manage elsewhere (git-tracked Overleaf project, etc.)
# Caps protect the laptop disk and bound worst-case writes. They apply to
# both copy *and* link mode (so a runaway agent can't fill your disk).
AAF_MANUSCRIPT_ROOT=./data/manuscripts
AAF_MANUSCRIPT_MAX_FILE_MB=50               # per-file write cap
AAF_MANUSCRIPT_MAX_BUNDLE_MB=500            # total bundle size cap

# ---- Compose-only knobs --------------------------------------------------
# Read by docker-compose.yml (NOT by backend/settings.py).
AAF_HTTP_PORT=8080                          # external port for the web SPA
POSTGRES_PASSWORD=aaf                       # postgres service password

# ---- TLS edge (production overlay) --------------------------------------
# Read by docker-compose.prod.yml + deploy/caddy/Caddyfile.example. Activate
# with: `docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d`
AAF_DOMAIN=localhost                        # public hostname Caddy serves
AAF_ACME_EMAIL=                             # Let's Encrypt notification inbox
AAF_TLS_HTTP_PORT=80                        # host port for HTTP→HTTPS upgrade
AAF_TLS_HTTPS_PORT=443                      # host port for HTTPS (TCP+UDP)

# ---- Optional MinIO profile ---------------------------------------------
# Enable with: `docker compose --profile storage up -d`
MINIO_ACCESS_KEY=aafadmin
MINIO_SECRET_KEY=aafadminsecret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
