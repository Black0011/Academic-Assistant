# =========================================================================
# Academic Agent Framework — LAPTOP profile (.env.laptop.example)
#
# A "personal-assistant on a laptop" preset:
#   - SQLite for tasks, no Postgres
#   - in-memory task queue, no Redis
#   - in-memory vector store, no Chroma persistence
#   - single-user (auth disabled)
#   - context auto-compaction on, so long writing/research sessions don't
#     blow the model's context window
#   - tight budget + parallelism caps so a runaway loop can't hog the box
#
# Usage:
#   cp .env.laptop.example .env.laptop
#   # then edit OPENAI_API_KEY (or DEEPSEEK_API_KEY etc.)
#   make dev-laptop
#
# This file is kept separate from .env on purpose - the production
# docker-compose stack reads .env, the laptop dev script reads
# .env.laptop. Set ONE per process.
# =========================================================================

# ---- Core ----------------------------------------------------------------
AAF_ENV=development
AAF_WORKDIR=./data
AAF_LOG_LEVEL=INFO
AAF_SECRET_KEY=local-dev-only-change-if-you-care

# ---- Auth (single user) -------------------------------------------------
AUTH_DISABLED=true
AUTH_ALLOW_SIGNUP=false
USERS_DIR=./data/users

# ---- Datastores: zero ops ------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/aaf.db
# Empty REDIS_URL keeps the in-memory session/queue backends.
REDIS_URL=

# Force the lighter backends explicitly so a stray default doesn't
# accidentally try to reach a Redis/Postgres that isn't running.
AAF_TASK_QUEUE_BACKEND=inmemory
AAF_TASK_STORE_BACKEND=sql
MEMORY_VECTOR_BACKEND=memory
MEMORY_SESSION_BACKEND=memory
# Leave knowledge/heuristic on YAML (durable on the host disk) and
# episodic on SQL (shares the SQLite db) — that's the auto default.

# ---- LLM (mock works out of the box; fill ONE for real work) -----------
# AAF boots fine with no keys (deterministic mock provider).  Add your
# real provider when you want real answers.
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# DeepSeek (works through the OpenAI-compatible adapter):
# DEFAULT_LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# Local models via Ollama:
# DEFAULT_LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# ---- Per-task model routing (recommended on laptop) --------------------
# Drop a config/model_routing.yaml that points "fast" at the cheap model
# and "reasoning" at the smart one - workflows will dispatch automatically.
AAF_MODEL_ROUTING_CONFIG=./config/model_routing.yaml

# ---- Context auto-compaction (on by default in laptop preset) ----------
# Cheap insurance against long writing sessions blowing the context window.
AAF_AUTOCOMPACT_ENABLED=true
AAF_AUTOCOMPACT_THRESHOLD=0.7
AAF_AUTOCOMPACT_KEEP_RECENT_N=6
AAF_AUTOCOMPACT_SUMMARISER_ROUTE=fast

# ---- MCP servers (off by default; opt in per server) -------------------
AAF_MCP_ENABLED=false
AAF_MCP_CONFIG=./config/mcp_servers.yaml

# ---- Self-evolution (off; flip on once you trust the heuristic queue) --
AAF_EVOLVER_ENABLED=false

# ---- Limits / Budgets (laptop-friendly) --------------------------------
AAF_MAX_PARALLEL_TASKS=2
AAF_DEFAULT_BUDGET_USD=0.5
AAF_SKILL_EXEC_TIMEOUT_S=120
AAF_CHECKPOINT_ENABLED=false
AAF_ALLOW_NETWORK=true
AAF_ALLOW_PAID_APIS=true

# ---- M8.1 · Gated proposals --------------------------------------------
AAF_PROPOSALS_BACKEND=yaml
AAF_PROPOSALS_DIR=./data/proposals

# ---- M8.2 · Planner DAG ------------------------------------------------
AAF_PLANNER_DEFAULT_MAX_NODES=20
AAF_PLANNER_DEFAULT_RETRY=1
AAF_PLANNER_MAX_PARALLEL=2
